{
  "name": "@kne/fastify-trtc-conference",
  "version": "1.0.23-alpha.2",
  "description": "基于腾讯云TRTC的Fastify视频会议插件，提供会议创建、成员管理、录像、AI转写等功能",
  "main": "index.js",
  "scripts": {
    "init": "husky",
    "dev": "nodemon ./index.js",
    "start": "node ./index.js",
    "test": "mocha test/**/*.test.js",
    "test:coverage": "nyc --reporter=html --reporter=text mocha test/**/*.test.js",
    "build:md": "npx @kne/md-doc",
    "start:md": "npx @kne/md-doc --watch",
    "prettier": "prettier --config .prettierrc --write '{libs/**/*,index}.{js,jsx,ts,tsx,json,css,scss}'",
    "lint-staged": "npx lint-staged"
  },
  "lint-staged": {
    "**/*.md": [
      "git add"
    ],
    "{libs/**/*,index}.{js,jsx,ts,tsx,json,css,scss}": [
      "prettier --config .prettierrc --write",
      "git add"
    ]
  },
  "files": [
    "index.js",
    "libs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kne-union/fastify-trtc-conference.git"
  },
  "keywords": [
    "fastify",
    "trtc",
    "conference",
    "video",
    "real-time-communication",
    "tencent-cloud",
    "recording",
    "ai-transcription",
    "webrtc"
  ],
  "author": "linzp",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kne-union/fastify-trtc-conference/issues"
  },
  "homepage": "https://github.com/kne-union/fastify-trtc-conference#readme",
  "peerDependencies": {
    "fastify-cron": "*",
    "@kne/fastify-namespace": "*",
    "@kne/fastify-sequelize": "*",
    "fastify-plugin": ">=5"
  },
  "devDependencies": {
    "@fastify/env": "^4.4.0",
    "@kne/fastify-sequelize": "^2.0.1",
    "fastify": "^5.3.2",
    "fastify-cron": "^1.4.0",
    "fastify-plugin": "^5.0.1",
    "husky": "^9.0.11",
    "mocha": "^11.7.5",
    "chai": "^6.2.2",
    "nyc": "^17.1.0",
    "nodemon": "^3.1.3",
    "prettier": "^3.2.5",
    "sqlite3": "^5.1.7"
  },
  "dependencies": {
    "@kne/fastify-shorten": "^1.0.12",
    "@kne/fastify-tencent": "^0.1.3",
    "@kne/fastify-trtc": "^1.0.0-alpha.1",
    "dayjs": "^1.11.13",
    "lodash": "^4.17.21"
  }
}
